# ============================================================
# FTax Environment Variables — copy to .env and fill in values
# ============================================================

# ----- API -----
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----- Database -----
DATABASE_URL=postgresql://ftax_user:ftax_password@localhost:5432/ftax_db

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- JWT -----
JWT_ACCESS_SECRET=change_me_access_secret_at_least_64_chars_long_xxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_64_chars_long_xxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- Email (Mailtrap - free dev SMTP) -----
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_password
MAIL_FROM=noreply@ftax.app

# ----- Encryption (for SSN/ITIN at rest) -----
ENCRYPTION_KEY=change_me_32_char_hex_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- App -----
APP_URL=http://localhost:3000
APP_NAME=FTax
