{
  "name": "ftax",
  "version": "1.0.0",
  "private": true,
  "description": "UIC F-1 International Student Tax Assistant",
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter web build && pnpm --filter api build",
    "lint": "pnpm --recursive run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "pnpm --recursive run test",
    "test:e2e": "pnpm --filter api test:e2e",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:studio": "pnpm --filter api db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
